---
import Section from '@components/layout/Section.astro';
import clients from '@/data/clients.json';

const doubledClients = [...clients, ...clients];
---

<Section padding="md" class="overflow-hidden">
  <p class="text-center text-sm uppercase tracking-widest text-slate-400 mb-10">
    Empresas que confian en nosotros
  </p>

  <div class="relative overflow-hidden">
    <!-- Fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-white to-transparent z-10"></div>
    <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-white to-transparent z-10"></div>

    <!-- Scrolling logos -->
    <div class="meridian-logo-scroll flex items-center gap-16 whitespace-nowrap">
      {doubledClients.map((client, i) => (
        <span class="text-slate-300 hover:text-slate-500 transition-colors text-lg font-bold tracking-wider shrink-0" key={`client-${i}`}>
          {client.name}
        </span>
      ))}
    </div>
  </div>
</Section>
