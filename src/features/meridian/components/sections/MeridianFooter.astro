---
import Container from '@components/layout/Container.astro';
---

<footer class="border-t border-slate-100 py-12 bg-white">
  <Container>
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-xl font-bold tracking-tight text-slate-900">
        GMI<span class="text-blue-600">2</span>
        <span class="text-sm font-normal text-slate-400 ml-2">Consulting</span>
      </div>

      <div class="flex items-center gap-8">
        <a href="#about" class="text-sm text-slate-400 hover:text-slate-700 transition-colors">Nosotros</a>
        <a href="#services" class="text-sm text-slate-400 hover:text-slate-700 transition-colors">Servicios</a>
        <a href="#cases" class="text-sm text-slate-400 hover:text-slate-700 transition-colors">Casos</a>
        <a href="#contact" class="text-sm text-slate-400 hover:text-slate-700 transition-colors">Contacto</a>
      </div>

      <p class="text-xs text-slate-300">
        &copy; {new Date().getFullYear()} GMI2 Consulting
      </p>
    </div>
  </Container>
</footer>
