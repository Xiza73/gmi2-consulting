---
import MeridianGlobe from '../three/MeridianGlobe';
import Button from '@components/ui/Button.astro';
---

<section class="relative min-h-screen flex items-center bg-white overflow-visible">
  <!-- 3D Globe — positioned absolutely so it can overflow -->
  <div class="hidden lg:block absolute top-1/2 right-0 -translate-y-1/2 w-[55%] h-[90vh] pointer-events-auto z-0">
    <MeridianGlobe client:only="react" />
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-32 pb-20 w-full pointer-events-none">
    <div class="max-w-xl pointer-events-auto">
      <!-- Content -->
      <p class="hero-eyebrow opacity-0 text-sm uppercase tracking-widest text-blue-600 mb-6 font-medium">
        IT Consulting & Software Development
      </p>

      <h1 class="hero-title opacity-0 text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight text-slate-900 leading-[1.05]">
        Soluciones
        <span class="text-blue-600">digitales</span>
        que generan impacto
      </h1>

      <p class="hero-description opacity-0 mt-8 text-lg text-slate-500 max-w-lg leading-relaxed">
        Consultoria tecnologica de alto nivel. Desarrollamos software a medida,
        productos SaaS y estrategias de transformacion digital para empresas ambiciosas.
      </p>

      <div class="hero-cta opacity-0 mt-10 flex flex-wrap gap-4">
        <Button variant="primary" size="lg" href="#contact" class="!bg-blue-600 hover:!bg-blue-700 !shadow-blue-600/25">
          Agendar Reunion
        </Button>
        <Button variant="outline" size="lg" href="#cases" class="!text-slate-700 !border-slate-300 hover:!border-blue-600 hover:!text-blue-600">
          Ver Proyectos
        </Button>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function initMeridianHero() {
    const hero = document.querySelector('.hero-title');
    if (!hero) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('.hero-eyebrow, .hero-title, .hero-description, .hero-cta', { opacity: 1 });
      return;
    }

    const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

    tl.to('.hero-eyebrow', { opacity: 1, y: 0, duration: 0.6 }, 0.3)
      .to('.hero-title', {
        opacity: 1,
        clipPath: 'inset(0 0% 0 0)',
        duration: 1.2,
        ease: 'power4.inOut',
      }, 0.4)
      .to('.hero-description', { opacity: 1, y: 0, duration: 0.8 }, 0.9)
      .to('.hero-cta', { opacity: 1, y: 0, duration: 0.8, stagger: 0.2 }, 1.1);
  }

  document.addEventListener('astro:page-load', initMeridianHero);
</script>
