      <div class="hidden md:flex items-center gap-8">
        <a href="#build" class="text-sm text-white/60 hover:text-white transition-colors font-medium">Que Hacemos</a>
        <a href="#process" class="text-sm text-white/60 hover:text-white transition-colors font-medium">Proceso</a>
        <a href="#tech" class="text-sm text-white/60 hover:text-white transition-colors font-medium">Tecnologias</a>
        <a href="#testimonials" class="text-sm text-white/60 hover:text-white transition-colors font-medium">Testimonios</a>
        <a
          href="#contact"
          class="px-5 py-2 text-sm font-bold text-white bg-gradient-to-r from-pink-500 to-orange-500 rounded-full hover:shadow-lg hover:shadow-pink-500/25 transition-all"
