---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import testimonials from '@/data/testimonials.json';
---

<Section id="testimonials" padding="lg">
  <Container>
    <div class="text-center mb-16">
      <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest font-bold mb-4" data-reveal-y="30">
        <span class="prism-gradient-text">Testimonios</span>
      </p>
      <h2 class="scroll-reveal opacity-0 text-4xl md:text-6xl font-black text-white" data-reveal-y="30" data-reveal-delay="0.1">
        Clientes felices
      </h2>
    </div>

    <!-- Masonry-like layout -->
    <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6" data-stagger-grid>
      {testimonials.map((t, i) => (
        <div
          class:list={['prism-card p-8 break-inside-avoid', i % 2 === 0 ? '' : 'md:mt-8']}
          data-stagger-item
        >
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="text-white/70 text-sm leading-relaxed mb-6">"{t.quote}"</p>

          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-r from-pink-500 to-orange-500 flex items-center justify-center text-white font-bold text-sm">
              {t.author.split(' ').map((n: string) => n[0]).join('')}
            </div>
            <div>
              <p class="text-sm font-bold text-white">{t.author}</p>
              <p class="text-xs text-white/40">{t.role} — {t.company}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </Container>
</Section>
