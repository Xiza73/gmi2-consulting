---
const words = ['SOFTWARE', 'SAAS', 'MOBILE', 'CLOUD', 'DEVOPS', 'FULL-STACK', 'AI', 'WEB'];
const marqueeContent = [...words, ...words].join(' • ') + ' • ';
---

<section class="py-12 overflow-hidden border-y border-white/5">
  <div class="prism-marquee">
    <div class="prism-marquee-track">
      <span class="text-6xl md:text-8xl font-black text-white/5 uppercase tracking-tighter whitespace-nowrap px-4">
        {marqueeContent}
      </span>
      <span class="text-6xl md:text-8xl font-black text-white/5 uppercase tracking-tighter whitespace-nowrap px-4">
        {marqueeContent}
      </span>
    </div>
  </div>
</section>
