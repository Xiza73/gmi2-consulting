---
import Container from '@components/layout/Container.astro';
---

<footer class="py-12 border-t" style="border-image: linear-gradient(90deg, #ec4899, #f97316, #eab308) 1;">
  <Container>
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-xl font-black tracking-tight text-white">
        GMI<span class="prism-gradient-text">2</span>
        <span class="text-sm font-normal text-white/30 ml-2">Consulting</span>
      </div>

      <div class="flex items-center gap-8">
        <a href="#build" class="text-sm text-white/40 hover:text-white/70 transition-colors">Servicios</a>
        <a href="#process" class="text-sm text-white/40 hover:text-white/70 transition-colors">Proceso</a>
        <a href="#tech" class="text-sm text-white/40 hover:text-white/70 transition-colors">Tech</a>
        <a href="#testimonials" class="text-sm text-white/40 hover:text-white/70 transition-colors">Testimonios</a>
      </div>

      <p class="text-xs text-white/20">
        &copy; {new Date().getFullYear()} GMI2 Consulting
      </p>
    </div>
  </Container>
</footer>
