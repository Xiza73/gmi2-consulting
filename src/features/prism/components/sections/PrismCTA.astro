---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
---

<Section id="contact" padding="xl" class="relative overflow-hidden prism-mesh-bg">
  <Container size="md">
    <div class="text-center scroll-reveal opacity-0" data-reveal-y="40">
      <h2 class="text-5xl md:text-7xl font-black text-white mb-6 leading-[0.95]">
        Hagamos algo
        <span class="block prism-gradient-text">increible juntos</span>
      </h2>

      <p class="text-lg text-white/50 max-w-xl mx-auto mb-10">
        Tu proximo producto digital esta a una conversacion de distancia.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="mailto:hello@gmi2consulting.com"
          class="px-10 py-5 text-lg font-black text-white bg-linear-to-r from-pink-500 via-orange-500 to-yellow-500 rounded-full hover:shadow-xl hover:shadow-pink-500/25 transition-all hover:scale-105"
        >
          Comenzar Proyecto
        </a>
      </div>

      <p class="mt-6 text-sm text-white/30">hello@gmi2consulting.com</p>
    </div>
  </Container>
</Section>
