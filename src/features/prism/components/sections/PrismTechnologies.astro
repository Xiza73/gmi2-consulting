---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';

interface TechItem {
  name: string;
  color: string;
  glow: string;
}

// 3 orbits: inner (core), middle (tools), outer (infra)
const innerTechs: TechItem[] = [
  { name: 'React', color: '#61dafb', glow: 'rgba(97,218,251,0.4)' },
  { name: 'TypeScript', color: '#3178c6', glow: 'rgba(49,120,198,0.4)' },
  { name: 'Node.js', color: '#68a063', glow: 'rgba(104,160,99,0.4)' },
  { name: 'Python', color: '#ffd43b', glow: 'rgba(255,212,59,0.4)' },
];

const middleTechs: TechItem[] = [
  { name: 'Next.js', color: '#ffffff', glow: 'rgba(255,255,255,0.3)' },
  { name: 'NestJS', color: '#e0234e', glow: 'rgba(224,35,78,0.4)' },
  { name: 'Flutter', color: '#02569b', glow: 'rgba(2,86,155,0.4)' },
  { name: 'GraphQL', color: '#e535ab', glow: 'rgba(229,53,171,0.4)' },
  { name: 'Tailwind', color: '#38bdf8', glow: 'rgba(56,189,248,0.4)' },
  { name: 'Prisma', color: '#5a67d8', glow: 'rgba(90,103,216,0.4)' },
];

const outerTechs: TechItem[] = [
  { name: 'AWS', color: '#ff9900', glow: 'rgba(255,153,0,0.4)' },
  { name: 'Docker', color: '#2496ed', glow: 'rgba(36,150,237,0.4)' },
  { name: 'Kubernetes', color: '#326ce5', glow: 'rgba(50,108,229,0.4)' },
  { name: 'PostgreSQL', color: '#4169e1', glow: 'rgba(65,105,225,0.4)' },
  { name: 'MongoDB', color: '#47a248', glow: 'rgba(71,162,72,0.4)' },
  { name: 'Redis', color: '#dc382d', glow: 'rgba(220,56,45,0.4)' },
  { name: 'CI/CD', color: '#f97316', glow: 'rgba(249,115,22,0.4)' },
  { name: 'React Native', color: '#61dafb', glow: 'rgba(97,218,251,0.4)' },
];
---

<Section id="tech" padding="lg">
  <Container>
    <div class="text-center mb-20">
      <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest font-bold mb-4" data-reveal-y="30">
        <span class="prism-gradient-text">Stack Tecnologico</span>
      </p>
      <h2 class="scroll-reveal opacity-0 text-4xl md:text-6xl font-black text-white mb-6" data-reveal-y="30" data-reveal-delay="0.1">
        Nuestras Herramientas
      </h2>
      <p class="scroll-reveal opacity-0 text-lg text-white/40 max-w-2xl mx-auto" data-reveal-y="20" data-reveal-delay="0.2">
        Dominamos las tecnologias mas demandadas del mercado para construir soluciones robustas y escalables.
      </p>
    </div>

    <!-- Orbit System -->
    <div class="relative w-full max-w-3xl mx-auto aspect-square scroll-reveal opacity-0" data-reveal-y="40" id="orbit-system">

      <!-- Orbit rings with gradient glow -->
      <div class="absolute inset-[32%] rounded-full border border-white/08 shadow-[0_0_40px_rgba(236,72,153,0.05)]"></div>
      <div class="absolute inset-[18%] rounded-full border border-white/06 shadow-[0_0_40px_rgba(249,115,22,0.04)]"></div>
      <div class="absolute inset-[8%] rounded-full border border-white/04 shadow-[0_0_40px_rgba(234,179,8,0.03)]"></div>

      <!-- Decorative orbit dots -->
      <div class="absolute inset-[32%] rounded-full prism-orbit" style="animation-duration: 60s;">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-pink-500/40"></div>
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-1 h-1 rounded-full bg-orange-500/30"></div>
      </div>
      <div class="absolute inset-[18%] rounded-full prism-orbit-reverse" style="animation-duration: 80s;">
        <div class="absolute top-1/2 left-0 -translate-x-1/2 -translate-y-1/2 w-1 h-1 rounded-full bg-yellow-500/30"></div>
      </div>

      <!-- Center piece -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20">
        <div class="relative group cursor-default">
          <!-- Pulse rings -->
          <div class="absolute inset-0 -m-3 rounded-full bg-linear-to-r from-pink-500/20 to-orange-500/20 animate-ping" style="animation-duration: 3s;"></div>
          <div class="absolute inset-0 -m-1.5 rounded-full bg-linear-to-r from-pink-500/10 to-orange-500/10 animate-pulse"></div>
          <!-- Core -->
          <div class="relative w-24 h-24 md:w-28 md:h-28 rounded-full bg-linear-to-br from-pink-500 via-orange-500 to-yellow-500 flex items-center justify-center shadow-2xl shadow-pink-500/30">
            <div class="text-center">
              <span class="text-white font-black text-2xl md:text-3xl block leading-none">GMI2</span>
              <span class="text-white/70 text-[9px] font-semibold uppercase tracking-wider">Consulting</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Inner Orbit: Core Tech (4 items) -->
      {innerTechs.map((tech, i) => {
        const angle = (i / innerTechs.length) * 360 - 90;
        const rad = (angle * Math.PI) / 180;
        return (
          <div
            class="orbit-item absolute z-10"
            style={`top: ${50 + 32 * Math.sin(rad)}%; left: ${50 + 32 * Math.cos(rad)}%; transform: translate(-50%, -50%);`}
          >
            <div
              class="group relative flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/06 border border-white/12 backdrop-blur-md cursor-default transition-all duration-300 hover:scale-110 hover:bg-white/12"
              style={`--tech-color: ${tech.color}; --tech-glow: ${tech.glow};`}
            >
              <!-- Color indicator -->
              <div class="w-2.5 h-2.5 rounded-full shrink-0 shadow-lg" style={`background: ${tech.color}; box-shadow: 0 0 12px ${tech.glow};`}></div>
              <span class="text-sm font-bold text-white/90 whitespace-nowrap">{tech.name}</span>
              <!-- Hover glow -->
              <div class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`box-shadow: 0 0 25px ${tech.glow}, inset 0 0 15px ${tech.glow};`}></div>
            </div>
          </div>
        );
      })}

      <!-- Middle Orbit: Framework/Tools (6 items) -->
      {middleTechs.map((tech, i) => {
        const angle = (i / middleTechs.length) * 360 - 60;
        const rad = (angle * Math.PI) / 180;
        return (
          <div
            class="orbit-item absolute z-10"
            style={`top: ${50 + 48 * Math.sin(rad)}%; left: ${50 + 48 * Math.cos(rad)}%; transform: translate(-50%, -50%);`}
          >
            <div
              class="group relative flex items-center gap-2 px-3 py-2 rounded-lg bg-white/04 border border-white/08 backdrop-blur-sm cursor-default transition-all duration-300 hover:scale-110 hover:bg-white/10"
            >
              <div class="w-2 h-2 rounded-full shrink-0" style={`background: ${tech.color}; box-shadow: 0 0 10px ${tech.glow};`}></div>
              <span class="text-xs font-semibold text-white/70 whitespace-nowrap group-hover:text-white/90 transition-colors">{tech.name}</span>
              <div class="absolute inset-0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`box-shadow: 0 0 20px ${tech.glow};`}></div>
            </div>
          </div>
        );
      })}

      <!-- Outer Orbit: Infra/DB (8 items) -->
      {outerTechs.map((tech, i) => {
        const angle = (i / outerTechs.length) * 360 - 30;
        const rad = (angle * Math.PI) / 180;
        return (
          <div
            class="orbit-item absolute z-10"
            style={`top: ${50 + 56 * Math.sin(rad)}%; left: ${50 + 56 * Math.cos(rad)}%; transform: translate(-50%, -50%);`}
          >
            <div
              class="group relative flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-white/03 border border-white/06 cursor-default transition-all duration-300 hover:scale-110 hover:bg-white/08"
            >
              <div class="w-1.5 h-1.5 rounded-full shrink-0" style={`background: ${tech.color}; box-shadow: 0 0 8px ${tech.glow};`}></div>
              <span class="text-[11px] font-medium text-white/50 whitespace-nowrap group-hover:text-white/80 transition-colors">{tech.name}</span>
              <div class="absolute inset-0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`box-shadow: 0 0 15px ${tech.glow};`}></div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Bottom stats -->
    <div class="relative z-20 flex justify-center gap-12 mt-24 scroll-reveal opacity-0" data-reveal-y="20" data-reveal-delay="0.3">
      <div class="text-center">
        <p class="text-3xl font-black prism-gradient-text">18+</p>
        <p class="text-sm text-white/40 mt-1">Tecnologias</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-black prism-gradient-text">5</p>
        <p class="text-sm text-white/40 mt-1">Categorias</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-black prism-gradient-text">100%</p>
        <p class="text-sm text-white/40 mt-1">Full-Stack</p>
      </div>
    </div>
  </Container>
</Section>

<script>
  import gsap from 'gsap';

  function initOrbitHover() {
    const items = document.querySelectorAll<HTMLElement>('.orbit-item');
    items.forEach((item) => {
      item.addEventListener('mouseenter', () => {
        gsap.to(item, { scale: 1.15, duration: 0.3, ease: 'back.out(1.7)' });
      });
      item.addEventListener('mouseleave', () => {
        gsap.to(item, { scale: 1, duration: 0.3, ease: 'power2.out' });
      });
    });
  }

  document.addEventListener('astro:page-load', initOrbitHover);
</script>
