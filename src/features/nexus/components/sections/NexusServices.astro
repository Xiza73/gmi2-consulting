---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import services from '@/data/services.json';

const iconMap: Record<string, string> = {
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  rocket: 'M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.63 8.37m5.96 6l-5.84 7.38',
  smartphone: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z',
  cloud: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
  lightbulb: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  settings: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z',
};
---

<Section id="services" padding="lg">
  <Container>
    <div class="text-center mb-16">
      <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest text-sky-400 mb-4 font-medium" data-reveal-y="30">
        Nuestros Servicios
      </p>
      <h2 class="scroll-reveal opacity-0 text-4xl md:text-5xl font-bold text-white" data-reveal-y="30" data-reveal-delay="0.1">
        Expertise que <span class="bg-clip-text text-transparent bg-gradient-to-r from-sky-400 to-cyan-400">impulsa</span> resultados
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, i) => (
        <div
          class="scroll-reveal opacity-0 group"
          data-reveal-y="30"
          data-reveal-delay={String(i * 0.08)}
        >
          <div class="nexus-card nexus-glow-hover p-8 h-full transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-sky-500/10 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconMap[service.icon] || iconMap.code} />
              </svg>
            </div>

            <h3 class="text-xl font-semibold text-white mb-3 group-hover:text-sky-400 transition-colors">{service.title}</h3>
            <p class="text-white/40 text-sm leading-relaxed mb-6">{service.description}</p>

            <ul class="space-y-2">
              {service.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm text-white/40">
                  <span class="w-1 h-1 rounded-full bg-sky-400 shrink-0"></span>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </Container>
</Section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initServicesReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('#services .scroll-reveal', { opacity: 1 });
      return;
    }

    gsap.utils.toArray<HTMLElement>('#services .scroll-reveal').forEach((el) => {
      const y = parseInt(el.dataset.revealY || '30');
      const delay = parseFloat(el.dataset.revealDelay || '0');

      gsap.fromTo(el,
        { opacity: 0, y },
        {
          opacity: 1, y: 0, duration: 0.8, delay,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        }
      );
    });
  }

  document.addEventListener('astro:page-load', initServicesReveal);
</script>
