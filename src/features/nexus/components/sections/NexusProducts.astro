---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';

const products = [
  {
    title: 'Plataformas SaaS',
    description: 'Productos multi-tenant con billing integrado, dashboards personalizables y APIs robustas.',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
    features: ['Multi-tenancy', 'Stripe / Billing', 'Role-based access', 'API REST + WebSockets'],
    accent: '#0ea5e9',
  },
  {
    title: 'Apps Moviles',
    description: 'Aplicaciones cross-platform con rendimiento nativo, offline-first y push notifications.',
    icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z',
    features: ['React Native / Flutter', 'Offline-first', 'Push notifications', 'App Store deployment'],
    accent: '#06b6d4',
  },
  {
    title: 'Soluciones Enterprise',
    description: 'Sistemas a medida para grandes organizaciones: ERP, CRM e integraciones complejas.',
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    features: ['ERP / CRM custom', 'SSO + LDAP', 'Audit logging', 'Legacy migration'],
    accent: '#8b5cf6',
  },
];
---

<Section id="products" padding="lg" class="nexus-dot-grid">
  <Container>
    <div class="text-center mb-16">
      <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest text-sky-400 mb-4 font-medium" data-reveal-y="30">
        Que Construimos
      </p>
      <h2 class="scroll-reveal opacity-0 text-4xl md:text-5xl font-bold text-white" data-reveal-y="30" data-reveal-delay="0.1">
        Productos digitales de <span class="bg-clip-text text-transparent bg-linear-to-r from-sky-400 to-cyan-400">clase mundial</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {products.map((product, i) => (
        <div
          class="scroll-reveal opacity-0 group"
          data-reveal-y="30"
          data-reveal-delay={String(i * 0.1)}
        >
          <div class="nexus-card nexus-glow-hover p-8 h-full transition-all duration-300 hover:-translate-y-1">
            <div
              class="w-12 h-12 rounded-lg flex items-center justify-center mb-6"
              style={`background: ${product.accent}15`}
            >
              <svg class="w-6 h-6" style={`color: ${product.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={product.icon} />
              </svg>
            </div>

            <h3 class="text-xl font-semibold text-white mb-3 group-hover:text-sky-400 transition-colors">{product.title}</h3>
            <p class="text-white/40 text-sm leading-relaxed mb-6">{product.description}</p>

            <ul class="space-y-2">
              {product.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm text-white/50">
                  <svg class="w-4 h-4 shrink-0" style={`color: ${product.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </Container>
</Section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initProductsReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('#products .scroll-reveal', { opacity: 1 });
      return;
    }

    gsap.utils.toArray<HTMLElement>('#products .scroll-reveal').forEach((el) => {
      const y = parseInt(el.dataset.revealY || '30');
      const delay = parseFloat(el.dataset.revealDelay || '0');

      gsap.fromTo(el,
        { opacity: 0, y },
        {
          opacity: 1, y: 0, duration: 0.8, delay,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        }
      );
    });
  }

  document.addEventListener('astro:page-load', initProductsReveal);
</script>
