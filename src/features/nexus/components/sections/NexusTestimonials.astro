---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import testimonials from '@/data/testimonials.json';
---

<Section id="testimonials" padding="lg">
  <Container>
    <div class="text-center mb-16">
      <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest text-sky-400 mb-4 font-medium" data-reveal-y="30">
        Testimonios
      </p>
      <h2 class="scroll-reveal opacity-0 text-4xl md:text-5xl font-bold text-white" data-reveal-y="30" data-reveal-delay="0.1">
        Lo que dicen nuestros <span class="bg-clip-text text-transparent bg-gradient-to-r from-sky-400 to-cyan-400">clientes</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div
          class="scroll-reveal opacity-0"
          data-reveal-y="30"
          data-reveal-delay={String(i * 0.1)}
        >
          <div class="nexus-card p-8 h-full transition-all duration-300 hover:-translate-y-1 nexus-glow-hover">
            <!-- Quote mark -->
            <svg class="w-8 h-8 text-sky-500/20 mb-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
            </svg>

            <p class="text-white/60 text-sm leading-relaxed mb-6">{t.quote}</p>

            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-sky-500/20 flex items-center justify-center text-sky-400 font-bold text-sm">
                {t.author.charAt(0)}
              </div>
              <div>
                <p class="text-white font-medium text-sm">{t.author}</p>
                <p class="text-white/30 text-xs">{t.company}</p>
              </div>
            </div>

            {t.rating && (
              <div class="flex gap-1 mt-4">
                {Array.from({ length: t.rating }).map((_, s) => (
                  <svg class="w-3.5 h-3.5 text-sky-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </Container>
</Section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initTestimonialsReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('#testimonials .scroll-reveal', { opacity: 1 });
      return;
    }

    gsap.utils.toArray<HTMLElement>('#testimonials .scroll-reveal').forEach((el) => {
      const y = parseInt(el.dataset.revealY || '30');
      const delay = parseFloat(el.dataset.revealDelay || '0');

      gsap.fromTo(el,
        { opacity: 0, y },
        {
          opacity: 1, y: 0, duration: 0.8, delay,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        }
      );
    });
  }

  document.addEventListener('astro:page-load', initTestimonialsReveal);
</script>
