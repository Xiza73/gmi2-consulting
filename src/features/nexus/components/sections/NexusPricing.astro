---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import Button from '@components/ui/Button.astro';
import pricing from '@/data/pricing.json';
---

<Section id="pricing" padding="lg">
  <Container>
    <div class="text-center mb-16">
      <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest text-sky-400 mb-4 font-medium" data-reveal-y="30">
        Precios
      </p>
      <h2 class="scroll-reveal opacity-0 text-4xl md:text-5xl font-bold text-white" data-reveal-y="30" data-reveal-delay="0.1">
        Planes que se adaptan a tu <span class="bg-clip-text text-transparent bg-linear-to-r from-sky-400 to-cyan-400">crecimiento</span>
      </h2>
      <p class="scroll-reveal opacity-0 mt-4 text-white/40 max-w-xl mx-auto" data-reveal-y="20" data-reveal-delay="0.2">
        Sin contratos a largo plazo. Escala tu equipo segun necesites.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto items-start">
      {pricing.map((plan, i) => (
        <div
          class="scroll-reveal opacity-0"
          data-reveal-y="30"
          data-reveal-delay={String(i * 0.15)}
        >
          <div
            class:list={[
              'relative rounded-2xl p-8 h-full transition-all duration-300 hover:-translate-y-1',
              plan.highlighted
                ? 'pricing-highlighted'
                : 'nexus-card',
            ]}
          >
            {plan.highlighted && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="px-4 py-1 text-xs font-semibold bg-sky-500 text-white rounded-full shadow-lg shadow-sky-500/25">
                  Mas Popular
                </span>
              </div>
            )}

            <h3 class="text-xl font-bold text-white mb-2">{plan.name}</h3>

            <div class="mb-4">
              {plan.currency ? (
                <div class="flex items-baseline gap-1">
                  <span class="text-sm text-white/50">Desde</span>
                  <span class="text-4xl font-bold text-white">${plan.price}</span>
                  <span class="text-white/40 text-sm">/{plan.period}</span>
                </div>
              ) : (
                <span class="text-4xl font-bold text-white">{plan.price}</span>
              )}
            </div>

            <p class="text-sm text-white/40 leading-relaxed mb-8">{plan.description}</p>

            <ul class="space-y-3 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm text-white/60">
                  <svg class="w-5 h-5 shrink-0 text-sky-400 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <Button
              variant={plan.highlighted ? 'primary' : 'outline'}
              size="lg"
              href="#contact"
              class:list={[
                'w-full justify-center',
                plan.highlighted
                  ? 'bg-sky-600! hover:bg-sky-700! shadow-sky-600/25!'
                  : 'text-white! border-white/20! hover:border-sky-500! hover:text-sky-400!',
              ]}
            >
              {plan.cta}
            </Button>
          </div>
        </div>
      ))}
    </div>
  </Container>
</Section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initPricingReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('#pricing .scroll-reveal', { opacity: 1 });
      return;
    }

    gsap.utils.toArray<HTMLElement>('#pricing .scroll-reveal').forEach((el) => {
      const y = parseInt(el.dataset.revealY || '30');
      const delay = parseFloat(el.dataset.revealDelay || '0');

      gsap.fromTo(el,
        { opacity: 0, y },
        {
          opacity: 1, y: 0, duration: 0.8, delay,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        }
      );
    });
  }

  document.addEventListener('astro:page-load', initPricingReveal);
</script>
