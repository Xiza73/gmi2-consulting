---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import Button from '@components/ui/Button.astro';
---

<Section id="contact" padding="lg">
  <Container size="md">
    <div class="scroll-reveal opacity-0 relative rounded-3xl overflow-hidden" data-reveal-y="40">
      <!-- Background glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-sky-600/20 via-cyan-600/10 to-transparent"></div>
      <div class="absolute top-0 right-0 w-64 h-64 bg-sky-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-cyan-500/10 rounded-full blur-3xl"></div>

      <div class="relative nexus-card p-12 md:p-16 text-center">
        <p class="text-sm uppercase tracking-widest text-sky-400 mb-4 font-medium">Empezar Ahora</p>

        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
          Listo para construir
          <span class="block bg-clip-text text-transparent bg-gradient-to-r from-sky-400 to-cyan-400">
            tu producto SaaS?
          </span>
        </h2>

        <p class="text-white/40 max-w-lg mx-auto mb-10 leading-relaxed">
          Agenda una reunion con nuestro equipo. Evaluaremos tu proyecto y te presentaremos
          una propuesta personalizada sin compromiso.
        </p>

        <div class="flex flex-wrap gap-4 justify-center">
          <Button variant="primary" size="lg" href="#" class="!bg-sky-600 hover:!bg-sky-700 !shadow-sky-600/25">
            Agendar Reunion
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
          <Button variant="secondary" size="lg" href="#dashboard">
            Ver Demo
          </Button>
        </div>
      </div>
    </div>
  </Container>
</Section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initCTAReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('#contact .scroll-reveal', { opacity: 1 });
      return;
    }

    gsap.utils.toArray<HTMLElement>('#contact .scroll-reveal').forEach((el) => {
      const y = parseInt(el.dataset.revealY || '40');

      gsap.fromTo(el,
        { opacity: 0, y },
        {
          opacity: 1, y: 0, duration: 1,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        }
      );
    });
  }

  document.addEventListener('astro:page-load', initCTAReveal);
</script>
