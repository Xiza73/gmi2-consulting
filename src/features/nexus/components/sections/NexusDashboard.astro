---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import NexusDashboardApp from './NexusDashboardApp';
---

<Section id="dashboard" padding="lg">
  <Container>
    <div class="scroll-reveal opacity-0 max-w-6xl mx-auto" data-reveal-y="40" data-reveal-delay="0.1">

      <!-- 3D Laptop Wrapper -->
      <div class="laptop-3d-wrapper laptop-open" id="laptop-wrapper">

        <!-- Lid (rotates on X axis) -->
        <div class="laptop-lid" id="laptop-lid">
          <!-- Front: Screen -->
          <div class="laptop-lid-front">
            <div class="laptop-screen">
              <!-- Top bezel with camera -->
              <div class="laptop-bezel-top">
                <div class="laptop-camera"></div>
              </div>
              <!-- Screen content -->
              <div class="laptop-screen-content relative overflow-hidden">
                <NexusDashboardApp client:visible />
              </div>
              <!-- Bottom bezel (chin) -->
              <div class="laptop-bezel-bottom"></div>
            </div>
          </div>
          <!-- Back: Lid exterior -->
          <div class="laptop-lid-back">
            <div class="laptop-lid-exterior">
              <div class="laptop-logo">
                <span>G2</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Base — front profile (thin wedge, like viewing a MacBook from the front) -->
        <div class="laptop-base">
          <div class="laptop-base-top-edge"></div>
          <div class="laptop-base-front"></div>
          <div class="laptop-base-bottom-edge"></div>
        </div>

        <!-- Toggle Button -->
        <button class="laptop-toggle-btn" id="laptop-toggle" aria-label="Cerrar laptop">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
          <span id="laptop-toggle-text">Cerrar</span>
        </button>
      </div>

    </div>
  </Container>
</Section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initDashboardReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('#dashboard .scroll-reveal', { opacity: 1 });
      return;
    }

    gsap.utils.toArray<HTMLElement>('#dashboard .scroll-reveal').forEach((el) => {
      const y = parseInt(el.dataset.revealY || '30');
      const delay = parseFloat(el.dataset.revealDelay || '0');

      gsap.fromTo(el,
        { opacity: 0, y },
        {
          opacity: 1, y: 0, duration: 1, delay,
          ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        }
      );
    });
  }

  function initLaptopAnimation() {
    const _wrapper = document.getElementById('laptop-wrapper');
    const _lid = document.getElementById('laptop-lid');
    const _btn = document.getElementById('laptop-toggle');
    const _txt = document.getElementById('laptop-toggle-text');
    if (!_wrapper || !_lid || !_btn || !_txt) return;

    const wrapper = _wrapper;
    const lid = _lid;
    const toggleBtn = _btn;
    const toggleText = _txt;

    let isOpen = true;
    let isAnimating = false;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const closeTl = gsap.timeline({ paused: true });
    closeTl.to(lid, {
      rotateX: -90,
      duration: 0.8,
      ease: 'power2.inOut',
    });

    function setOpen() {
      wrapper.classList.replace('laptop-closed', 'laptop-open');
      toggleBtn.classList.remove('is-closed');
      toggleText.textContent = 'Cerrar';
      toggleBtn.setAttribute('aria-label', 'Cerrar laptop');
      isOpen = true;
      isAnimating = false;
    }

    function setClosed() {
      wrapper.classList.replace('laptop-open', 'laptop-closed');
      toggleBtn.classList.add('is-closed');
      toggleText.textContent = 'Abrir';
      toggleBtn.setAttribute('aria-label', 'Abrir laptop');
      isOpen = false;
      isAnimating = false;
    }

    function toggle() {
      if (isAnimating) return;
      isAnimating = true;

      if (isOpen) {
        if (reducedMotion) {
          gsap.set(lid, { rotateX: -90 });
          setClosed();
          return;
        }
        closeTl.play().then(setClosed);
      } else {
        if (reducedMotion) {
          gsap.set(lid, { rotateX: 0 });
          setOpen();
          return;
        }
        closeTl.reverse().then(setOpen);
      }
    }

    toggleBtn.addEventListener('click', toggle);

    document.addEventListener('astro:before-swap', () => {
      closeTl.kill();
    }, { once: true });
  }

  document.addEventListener('astro:page-load', () => {
    initDashboardReveal();
    initLaptopAnimation();
  });
</script>
