---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import AnimatedCounter from '@components/animations/AnimatedCounter.astro';
import stats from '@/data/stats.json';
---

<Section padding="md">
  <Container>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {stats.map((stat) => (
        <div class="glass-card neon-glow p-6 md:p-8 text-center" data-stagger-item>
          <div class="text-4xl md:text-5xl font-bold text-white mb-2">
            <AnimatedCounter value={stat.value} suffix={stat.suffix} />
          </div>
          <p class="text-sm text-white/40 uppercase tracking-wider">{stat.label}</p>
        </div>
      ))}
    </div>
  </Container>
</Section>
