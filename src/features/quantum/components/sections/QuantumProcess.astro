---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import GradientText from '@components/ui/GradientText.astro';

const steps = [
  {
    number: '01',
    title: 'Discovery',
    description: 'Analizamos tu negocio, objetivos y desafios tecnologicos para definir la estrategia optima.',
    icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  },
  {
    number: '02',
    title: 'Design',
    description: 'Diseñamos la arquitectura, UX/UI y plan de desarrollo con sprints claros y medibles.',
    icon: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z',
  },
  {
    number: '03',
    title: 'Build',
    description: 'Desarrollamos con metodologias agiles, code reviews y testing automatizado continuo.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    number: '04',
    title: 'Launch',
    description: 'Desplegamos a produccion con monitoreo, optimizacion y soporte post-lanzamiento.',
    icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  },
];
---

<Section id="process" padding="lg">
  <Container>
    <div class="text-center mb-16 scroll-reveal opacity-0" data-reveal-y="40">
      <p class="text-sm uppercase tracking-widest text-primary-400 mb-4">Nuestro Proceso</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white">
        De la <GradientText from="#6366f1" to="#8b5cf6">idea</GradientText> al <GradientText from="#8b5cf6" to="#06b6d4">producto</GradientText>
      </h2>
    </div>

    <!-- Progress Bar -->
    <div class="relative mb-16 hidden lg:block">
      <div class="h-0.5 bg-white/10 rounded-full">
        <div class="quantum-progress-bar h-full rounded-full transition-all duration-300" id="process-progress" style="width: 0%"></div>
      </div>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" id="process-steps">
      {steps.map((step, index) => (
        <div class="process-step opacity-0 group" data-step-index={index}>
          <div class="glass-card p-8 h-full relative overflow-hidden">
            <!-- Step Number -->
            <span class="text-6xl font-bold text-white/5 absolute -top-2 -right-2">
              {step.number}
            </span>

            <!-- Icon -->
            <div class="w-14 h-14 rounded-xl bg-primary-500/20 flex items-center justify-center mb-6 neon-glow">
              <svg class="w-7 h-7 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
              </svg>
            </div>

            <h3 class="text-xl font-semibold text-white mb-3">{step.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</Section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initQuantumProcess() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('.process-step', { opacity: 1 });
      return;
    }

    const steps = gsap.utils.toArray<HTMLElement>('.process-step');
    const progressBar = document.getElementById('process-progress');

    steps.forEach((step, i) => {
      gsap.to(step, {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: step,
          start: 'top 80%',
          toggleActions: 'play none none none',
          onEnter: () => {
            if (progressBar) {
              gsap.to(progressBar, {
                width: `${((i + 1) / steps.length) * 100}%`,
                duration: 0.6,
                ease: 'power2.out',
              });
            }
          },
        },
      });
    });
  }

  document.addEventListener('astro:page-load', initQuantumProcess);
</script>
