---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import GradientText from '@components/ui/GradientText.astro';
import techStack from '@/data/tech-stack.json';
---

<Section id="tech" padding="lg">
  <Container>
    <div class="text-center mb-16 scroll-reveal opacity-0" data-reveal-y="40">
      <p class="text-sm uppercase tracking-widest text-primary-400 mb-4">Stack Tecnologico</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white">
        Las <GradientText from="#6366f1" to="#06b6d4">mejores herramientas</GradientText>
      </h2>
    </div>

    <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 md:gap-6" data-stagger-grid>
      {techStack.map((tech, i) => (
        <div
          class="glass-card p-6 flex flex-col items-center justify-center gap-3 hover:border-primary-500/30 transition-all duration-300 group"
          data-stagger-item
          data-parallax={0.1 + (i % 3) * 0.05}
        >
          <div class="w-10 h-10 rounded-lg bg-primary-500/20 flex items-center justify-center group-hover:bg-primary-500/30 transition-colors">
            <span class="text-xs font-bold text-primary-400">{tech.name.slice(0, 2).toUpperCase()}</span>
          </div>
          <span class="text-xs text-white/50 font-medium text-center">{tech.name}</span>
        </div>
      ))}
    </div>
  </Container>
</Section>
