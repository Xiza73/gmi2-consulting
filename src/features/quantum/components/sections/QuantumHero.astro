---
import QuantumParticleField from '../three/QuantumParticleField';
import FloatingPolyhedra from '../three/FloatingPolyhedra';
import Badge from '@components/ui/Badge.astro';
import Button from '@components/ui/Button.astro';
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- 3D Background: Particles -->
  <div class="absolute inset-0 -z-10">
    <QuantumParticleField client:only="react" />
  </div>

  <!-- 3D Foreground: Floating Polyhedra (interactive) -->
  <div class="absolute inset-0 hidden lg:block z-[1]">
    <FloatingPolyhedra client:only="react" />
  </div>

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#030014]/50 to-[#030014] pointer-events-none z-[2]"></div>

  <!-- Content -->
  <div class="relative z-[3] mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-32 pb-20 pointer-events-none">
    <div class="max-w-4xl pointer-events-auto">
      <Badge variant="primary" class="hero-eyebrow opacity-0 mb-6">
        Consultoria IT & Desarrollo de Software
      </Badge>

      <h1 class="hero-title opacity-0 text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white leading-[0.95]">
        We Build
        <span class="block bg-clip-text text-transparent bg-gradient-to-r from-primary-400 via-accent-violet to-accent-cyan">
          The Future
        </span>
      </h1>

      <p class="hero-description opacity-0 mt-8 text-lg md:text-xl text-white/60 max-w-2xl leading-relaxed">
        Transformamos ideas en productos digitales de clase mundial.
        Desarrollo full-stack, SaaS, apps moviles y consultoria tecnologica.
      </p>

      <div class="hero-cta opacity-0 mt-10 flex flex-wrap gap-4">
        <Button variant="primary" size="lg" href="#contact">
          Iniciar Proyecto
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
        <Button variant="secondary" size="lg" href="#services">
          Ver Servicios
        </Button>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50">
    <span class="text-xs text-white/50 uppercase tracking-widest">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-white/50 to-transparent animate-pulse"></div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function initQuantumHero() {
    const hero = document.querySelector('.hero-title');
    if (!hero) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('.hero-eyebrow, .hero-title, .hero-description, .hero-cta', { opacity: 1 });
      return;
    }

    const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

    tl.to('.hero-eyebrow', { opacity: 1, y: 0, duration: 0.6 }, 0.3)
      .to('.hero-title', { opacity: 1, y: 0, duration: 1 }, 0.5)
      .to('.hero-description', { opacity: 1, y: 0, duration: 0.8 }, 0.9)
      .to('.hero-cta', { opacity: 1, y: 0, duration: 0.8 }, 1.1);
  }

  document.addEventListener('astro:page-load', initQuantumHero);
</script>
