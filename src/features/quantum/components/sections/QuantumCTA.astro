---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import Button from '@components/ui/Button.astro';
---

<Section id="contact" padding="xl" class="relative overflow-hidden">
  <!-- Background Effects -->
  <div class="absolute inset-0 -z-10" data-parallax="0.3">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute top-1/4 left-1/4 w-[300px] h-[300px] bg-accent-violet/10 rounded-full blur-[80px]"></div>
  </div>

  <Container size="md">
    <div class="text-center scroll-reveal opacity-0" data-reveal-y="40">
      <h2 class="text-4xl md:text-6xl font-bold text-white mb-6">
        ¿Listo para<br />
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary-400 to-accent-cyan">
          transformar tu negocio?
        </span>
      </h2>

      <p class="text-lg text-white/50 max-w-xl mx-auto mb-10">
        Hablemos sobre tu proximo proyecto. Te ayudamos a convertir tu vision en realidad.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <Button variant="primary" size="lg" href="mailto:hello@gmi2consulting.com">
          Agendar Reunion
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
        <Button variant="secondary" size="lg" href="mailto:hello@gmi2consulting.com">
          hello@gmi2consulting.com
        </Button>
      </div>
    </div>
  </Container>
</Section>
