---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import GradientText from '@components/ui/GradientText.astro';
import testimonials from '@/data/testimonials.json';
---

<Section id="testimonials" padding="lg">
  <Container>
    <div class="text-center mb-16 scroll-reveal opacity-0" data-reveal-y="40">
      <p class="text-sm uppercase tracking-widest text-primary-400 mb-4">Testimonios</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white">
        Lo que dicen <GradientText from="#6366f1" to="#8b5cf6">nuestros clientes</GradientText>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger-grid>
      {testimonials.slice(0, 6).map((testimonial) => (
        <div class="glass-card p-8 flex flex-col" data-stagger-item>
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-white/70 text-sm leading-relaxed flex-1 mb-6">
            "{testimonial.quote}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-accent-violet flex items-center justify-center text-white font-bold text-sm">
              {testimonial.author.split(' ').map((n: string) => n[0]).join('')}
            </div>
            <div>
              <p class="text-sm font-medium text-white">{testimonial.author}</p>
              <p class="text-xs text-white/40">{testimonial.role} — {testimonial.company}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </Container>
</Section>
