---
import type { Locale } from '@/i18n/config';
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import {
  TECHNOLOGIES_HEADER,
  INNER_TECHS,
  MIDDLE_TECHS,
  OUTER_TECHS,
  TECH_BOTTOM_STATS,
} from '../../data/technologies.data';

// Mobile marquee rows — shuffle the 18 techs across 4 rows so each row
// has a visually varied mix (not sorted by category). Rows alternate
// scroll direction + speed for an organic, non-robotic feel.
const allTechs = [...INNER_TECHS, ...MIDDLE_TECHS, ...OUTER_TECHS];
const mobileRows = [
  // Row 1 → scroll left, fastest
  [allTechs[0], allTechs[6], allTechs[13], allTechs[4], allTechs[16]],
  // Row 2 → scroll right, medium
  [allTechs[1], allTechs[12], allTechs[9], allTechs[17], allTechs[2]],
  // Row 3 → scroll left, slow
  [allTechs[3], allTechs[15], allTechs[10], allTechs[8]],
  // Row 4 → scroll right, medium-fast
  [allTechs[5], allTechs[11], allTechs[14], allTechs[7]],
].map((row) => row.filter(Boolean));

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const header = TECHNOLOGIES_HEADER[locale];
const bottomStats = TECH_BOTTOM_STATS[locale];
const innerTechs = INNER_TECHS;
const middleTechs = MIDDLE_TECHS;
const outerTechs = OUTER_TECHS;
---

<Section id="tech" padding="lg">
  <Container>
    <div class="text-center mb-20">
      <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest font-bold mb-4" data-reveal-y="30">
        <span class="forge-gradient-text">{header.eyebrow}</span>
      </p>
      <h2 class="scroll-reveal opacity-0 text-4xl md:text-6xl font-black text-white mb-6" data-reveal-y="30" data-reveal-delay="0.1">
        {header.title}
      </h2>
      <p class="scroll-reveal opacity-0 text-lg text-white/40 max-w-2xl mx-auto" data-reveal-y="20" data-reveal-delay="0.2">
        {header.subtitle}
      </p>
    </div>

    <!-- Orbit System — desktop only (>= md).
         On mobile the orbit radii and chip widths don't fit the viewport,
         so chips get clipped. A flex-wrap grid is used instead below. -->
    <div class="relative w-full max-w-3xl mx-auto aspect-square scroll-reveal opacity-0 hidden md:block" data-reveal-y="40" id="forge-orbit-system">

      <!-- Orbit rings — solid -->
      <div class="absolute inset-[32%] rounded-full border border-white/8 shadow-[0_0_40px_rgba(236,72,153,0.05)] forge-ring-inner"></div>
      <div class="absolute inset-[18%] rounded-full border border-white/6 shadow-[0_0_40px_rgba(249,115,22,0.04)] forge-ring-middle"></div>
      <div class="absolute inset-[8%] rounded-full border border-white/4 shadow-[0_0_40px_rgba(234,179,8,0.03)] forge-ring-outer"></div>

      <!-- Traveling particles on orbits -->
      <div class="absolute inset-[32%] rounded-full forge-orbit" style="animation-duration: 12s;">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-pink-500/60 shadow-[0_0_12px_rgba(236,72,153,0.8)]"></div>
      </div>
      <div class="absolute inset-[32%] rounded-full forge-orbit-reverse" style="animation-duration: 18s;">
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-1.5 h-1.5 rounded-full bg-orange-400/50 shadow-[0_0_10px_rgba(249,115,22,0.7)]"></div>
      </div>
      <div class="absolute inset-[18%] rounded-full forge-orbit" style="animation-duration: 25s;">
        <div class="absolute top-1/2 right-0 translate-x-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-yellow-400/50 shadow-[0_0_10px_rgba(234,179,8,0.6)]"></div>
      </div>
      <div class="absolute inset-[18%] rounded-full forge-orbit-reverse" style="animation-duration: 30s;">
        <div class="absolute top-0 left-1/4 -translate-y-1/2 w-1 h-1 rounded-full bg-pink-400/40 shadow-[0_0_8px_rgba(236,72,153,0.5)]"></div>
      </div>
      <div class="absolute inset-[8%] rounded-full forge-orbit" style="animation-duration: 40s;">
        <div class="absolute bottom-0 right-1/4 translate-y-1/2 w-1 h-1 rounded-full bg-orange-400/30 shadow-[0_0_6px_rgba(249,115,22,0.4)]"></div>
      </div>

      <!-- Center piece -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20">
        <div class="relative group cursor-default">
          <div class="absolute inset-0 -m-5 rounded-full bg-linear-to-r from-pink-500/15 to-orange-500/15 animate-ping" style="animation-duration: 3s;"></div>
          <div class="absolute inset-0 -m-3 rounded-full bg-linear-to-r from-pink-500/10 to-orange-500/10 animate-pulse"></div>
          <div class="forge-center-orb relative w-24 h-24 md:w-28 md:h-28 rounded-full bg-linear-to-br from-pink-500 via-orange-500 to-yellow-500 flex items-center justify-center shadow-2xl shadow-pink-500/30">
            <div class="text-center">
              <span class="text-white font-black text-2xl md:text-3xl block leading-none">GMI2</span>
              <span class="text-white/70 text-[9px] font-semibold uppercase tracking-wider">Consulting</span>
            </div>
          </div>
        </div>
      </div>

      <!--
        Inner orbit wrapper: rotates the whole group via CSS transform (GPU).
        Each item counter-rotates to keep text upright.
      -->
      <div class="absolute inset-0 forge-rotate-cw z-10 pointer-events-none" style="--orbit-duration: 120s;">
        {innerTechs.map((tech, i) => {
          const angle = (i / innerTechs.length) * 360 - 90;
          const rad = (angle * Math.PI) / 180;
          return (
            <div
              class="forge-orbit-item forge-counter-cw absolute"
              style={`top: ${50 + 32 * Math.sin(rad)}%; left: ${50 + 32 * Math.cos(rad)}%; translate: -50% -50%; --orbit-duration: 120s;`}
            >
              <div class="forge-tech-chip relative flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/6 border border-white/12 backdrop-blur-md cursor-pointer pointer-events-auto" data-glow={tech.glow}>
                <div class="forge-tech-dot w-2.5 h-2.5 rounded-full shrink-0 shadow-lg" style={`background: ${tech.color}; box-shadow: 0 0 12px ${tech.glow};`}></div>
                <span class="text-sm font-bold text-white/90 whitespace-nowrap">{tech.name}</span>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Middle orbit wrapper: rotates reverse -->
      <div class="absolute inset-0 forge-rotate-ccw z-10 pointer-events-none" style="--orbit-duration: 180s;">
        {middleTechs.map((tech, i) => {
          const angle = (i / middleTechs.length) * 360 - 60;
          const rad = (angle * Math.PI) / 180;
          return (
            <div
              class="forge-orbit-item forge-counter-ccw absolute"
              style={`top: ${50 + 48 * Math.sin(rad)}%; left: ${50 + 48 * Math.cos(rad)}%; translate: -50% -50%; --orbit-duration: 180s;`}
            >
              <div class="forge-tech-chip relative flex items-center gap-2 px-3 py-2 rounded-lg bg-white/4 border border-white/8 backdrop-blur-sm cursor-pointer pointer-events-auto" data-glow={tech.glow}>
                <div class="forge-tech-dot w-2 h-2 rounded-full shrink-0" style={`background: ${tech.color}; box-shadow: 0 0 10px ${tech.glow};`}></div>
                <span class="text-xs font-semibold text-white/70 whitespace-nowrap">{tech.name}</span>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Outer items: float, no orbit -->
      {outerTechs.map((tech, i) => {
        const angle = (i / outerTechs.length) * 360 - 30;
        const rad = (angle * Math.PI) / 180;
        return (
          <div
            class="forge-orbit-item forge-float-item absolute z-10"
            style={`top: ${50 + 56 * Math.sin(rad)}%; left: ${50 + 56 * Math.cos(rad)}%; transform: translate(-50%, -50%); --float-duration: ${3.5 + (i * 0.4)}s; --float-delay: ${-i * 0.5}s;`}
          >
            <div class="forge-tech-chip relative flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-white/3 border border-white/6 cursor-pointer pointer-events-auto" data-glow={tech.glow}>
              <div class="forge-tech-dot w-1.5 h-1.5 rounded-full shrink-0" style={`background: ${tech.color}; box-shadow: 0 0 8px ${tech.glow};`}></div>
              <span class="text-[11px] font-medium text-white/50 whitespace-nowrap">{tech.name}</span>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Mobile-only layout: 4 infinite marquees, alternating directions,
         varied speeds. No center orb. Pure CSS animation, zero JS cost.
         Each row's chip list is duplicated inline so `translateX(-50%)`
         produces a seamless loop. -->
    <div class="md:hidden scroll-reveal opacity-0 -mx-4 sm:-mx-6" data-reveal-y="30" id="forge-tech-mobile">
      {mobileRows.map((row, rowIdx) => {
        const directions = ['left', 'right', 'left', 'right'] as const;
        const durations = ['32s', '40s', '48s', '36s'];
        const direction = directions[rowIdx] ?? 'left';
        const duration = durations[rowIdx] ?? '40s';
        // Duplicate the row twice for a seamless loop.
        const doubled = [...row, ...row];
        return (
          <div class="forge-tech-marquee overflow-hidden py-2">
            <div
              class={`forge-tech-marquee-track forge-tech-marquee-${direction} flex gap-3 w-max`}
              style={`animation-duration: ${duration};`}
            >
              {doubled.map((tech, i) => (
                <div
                  class="flex items-center gap-2 px-3.5 py-2 rounded-xl bg-white/6 border border-white/12 backdrop-blur-md shrink-0"
                  aria-hidden={i >= row.length ? 'true' : undefined}
                >
                  <div class="forge-tech-dot w-2 h-2 rounded-full shrink-0" style={`background: ${tech.color}; box-shadow: 0 0 10px ${tech.glow};`}></div>
                  <span class="text-xs font-semibold text-white/85 whitespace-nowrap">{tech.name}</span>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Bottom stats -->
    <div class="relative z-20 flex justify-center gap-12 mt-24 scroll-reveal opacity-0" data-reveal-y="20" data-reveal-delay="0.3">
      {bottomStats.map((stat) => (
        <div class="text-center">
          <p class="text-3xl font-black forge-gradient-text">{stat.value}</p>
          <p class="text-sm text-white/40 mt-1">{stat.label}</p>
        </div>
      ))}
    </div>
  </Container>
</Section>

<style>
  /* Orbit ring subtle rotation */
  .forge-ring-inner { animation: forge-spin 60s linear infinite; }
  .forge-ring-middle { animation: forge-spin 90s linear infinite reverse; }
  .forge-ring-outer { animation: forge-spin 120s linear infinite; }

  @keyframes forge-spin {
    to { transform: rotate(360deg); }
  }

  /* Wrapper rotation — GPU-composited, butter smooth */
  .forge-rotate-cw {
    animation: forge-spin var(--orbit-duration, 120s) linear infinite;
    will-change: transform;
  }
  .forge-rotate-ccw {
    animation: forge-spin var(--orbit-duration, 180s) linear infinite reverse;
    will-change: transform;
  }

  /* Counter-rotation on each item so text stays upright */
  .forge-counter-cw {
    animation: forge-spin var(--orbit-duration, 120s) linear infinite reverse;
    will-change: transform;
  }
  .forge-counter-ccw {
    animation: forge-spin var(--orbit-duration, 180s) linear infinite;
    will-change: transform;
  }

  /* Outer items: gentle float */
  .forge-float-item {
    animation: forge-float var(--float-duration, 4s) ease-in-out infinite var(--float-delay, 0s);
  }

  @keyframes forge-float {
    0%, 100% { translate: -50% -50%; }
    50% { translate: -50% calc(-50% - 8px); }
  }

  /* Tech dot pulse */
  .forge-tech-dot {
    animation: forge-dot-pulse 2.5s ease-in-out infinite var(--dot-delay, 0s);
  }

  @keyframes forge-dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.4); }
  }

  /* Center orb breathing */
  .forge-center-orb {
    animation: forge-breathe 4s ease-in-out infinite;
  }

  @keyframes forge-breathe {
    0%, 100% { transform: scale(1); box-shadow: 0 25px 50px -12px rgba(236,72,153,0.3); }
    50% { transform: scale(1.05); box-shadow: 0 25px 60px -8px rgba(236,72,153,0.5), 0 0 80px rgba(249,115,22,0.15); }
  }

  /* Mobile marquee rows — infinite horizontal scroll.
     Content is duplicated inline so translateX(-50%) loops seamlessly. */
  .forge-tech-marquee-track {
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    will-change: transform;
  }
  .forge-tech-marquee-left {
    animation-name: forge-tech-marquee-l;
  }
  .forge-tech-marquee-right {
    animation-name: forge-tech-marquee-r;
  }

  @keyframes forge-tech-marquee-l {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes forge-tech-marquee-r {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  /* Edge fade mask — fades chips in/out at the sides instead of a hard cut. */
  .forge-tech-marquee {
    mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .forge-ring-inner, .forge-ring-middle, .forge-ring-outer,
    .forge-rotate-cw, .forge-rotate-ccw,
    .forge-counter-cw, .forge-counter-ccw,
    .forge-float-item, .forge-tech-dot, .forge-center-orb,
    .forge-tech-marquee-track {
      animation: none !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initForgeTech() {
    const system = document.getElementById('forge-orbit-system');
    if (!system) return;

    const items = system.querySelectorAll<HTMLElement>('.forge-orbit-item');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Randomize dot pulse delays
    items.forEach((item) => {
      const dot = item.querySelector<HTMLElement>('.forge-tech-dot');
      if (dot) {
        dot.style.setProperty('--dot-delay', `${-Math.random() * 2.5}s`);
      }
    });

    if (reducedMotion) return;

    // Staggered entrance (opacity only)
    gsap.set(items, { opacity: 0 });
    ScrollTrigger.create({
      trigger: system,
      start: 'top 70%',
      once: true,
      onEnter: () => {
        gsap.to(items, {
          opacity: 1,
          duration: 0.6,
          stagger: { each: 0.06, from: 'center' },
          ease: 'power2.out',
        });
      },
    });

    // Hover: scale + glow in ONE tween (both happen simultaneously)
    const chips = system.querySelectorAll<HTMLElement>('.forge-tech-chip');
    chips.forEach((chip) => {
      const glow = chip.dataset.glow || 'rgba(236,72,153,0.4)';

      chip.addEventListener('mouseenter', () => {
        gsap.to(chip, {
          scale: 1.15,
          boxShadow: `0 0 25px ${glow}, inset 0 0 12px ${glow}`,
          backgroundColor: 'rgba(255,255,255,0.12)',
          duration: 0.35,
          ease: 'power2.out',
        });
      });

      chip.addEventListener('mouseleave', () => {
        gsap.to(chip, {
          scale: 1,
          boxShadow: 'none',
          backgroundColor: '',
          duration: 0.4,
          ease: 'power2.out',
          clearProps: 'backgroundColor',
        });
      });
    });

    // Random highlight pulse
    function randomPulse() {
      const idx = Math.floor(Math.random() * chips.length);
      const chip = chips[idx];
      if (!chip) return;
      const glow = chip.dataset.glow || 'rgba(236,72,153,0.4)';

      gsap.timeline()
        .to(chip, { boxShadow: `0 0 20px ${glow}, 0 0 40px ${glow}`, duration: 0.5, ease: 'power2.out' })
        .to(chip, { boxShadow: 'none', duration: 1, ease: 'power2.inOut' });
    }

    const interval = setInterval(randomPulse, 2500);

    document.addEventListener('astro:before-swap', () => {
      clearInterval(interval);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initForgeTech);
</script>
