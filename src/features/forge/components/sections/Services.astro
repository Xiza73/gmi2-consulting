---
import Section from "@components/layout/Section.astro";
import Container from "@components/layout/Container.astro";
import {
  SERVICES,
  SERVICES_HEADER,
  SERVICE_ICON_PATHS,
} from "../../data/services.data";

const services = SERVICES;

const bentoSizes = [
  "md:col-span-2 md:row-span-2",
  "md:col-span-1 md:row-span-1",
  "md:col-span-1 md:row-span-1",
  "md:col-span-1 md:row-span-2",
  "md:col-span-1 md:row-span-1",
  "md:col-span-1 md:row-span-1",
];

const gradients = [
  "from-pink-500/20 to-orange-500/20",
  "from-orange-500/20 to-yellow-500/20",
  "from-violet-500/20 to-pink-500/20",
  "from-cyan-500/20 to-blue-500/20",
  "from-yellow-500/20 to-orange-500/20",
  "from-pink-500/20 to-violet-500/20",
];

const accentColors = [
  {
    border: "border-pink-500/30",
    text: "text-pink-400",
    bg: "bg-pink-500/10",
    glow: "shadow-pink-500/20",
  },
  {
    border: "border-orange-500/30",
    text: "text-orange-400",
    bg: "bg-orange-500/10",
    glow: "shadow-orange-500/20",
  },
  {
    border: "border-violet-500/30",
    text: "text-violet-400",
    bg: "bg-violet-500/10",
    glow: "shadow-violet-500/20",
  },
  {
    border: "border-cyan-500/30",
    text: "text-cyan-400",
    bg: "bg-cyan-500/10",
    glow: "shadow-cyan-500/20",
  },
  {
    border: "border-yellow-500/30",
    text: "text-yellow-400",
    bg: "bg-yellow-500/10",
    glow: "shadow-yellow-500/20",
  },
  {
    border: "border-pink-500/30",
    text: "text-pink-400",
    bg: "bg-pink-500/10",
    glow: "shadow-pink-500/20",
  },
];

const iconPaths = SERVICE_ICON_PATHS;
---

<Section id="build" padding="lg">
  <Container>
    <div class="text-center mb-16">
      <p
        class="scroll-reveal opacity-0 text-sm uppercase tracking-widest font-bold mb-4"
        data-reveal-y="30"
      >
        <span class="forge-gradient-text">{SERVICES_HEADER.eyebrow}</span>
      </p>
      <h2
        class="scroll-reveal opacity-0 text-4xl md:text-6xl font-black text-white"
        data-reveal-y="30"
        data-reveal-delay="0.1"
      >
        {SERVICES_HEADER.title}
      </h2>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-4 md:auto-rows-[minmax(200px,auto)]"
      data-stagger-grid
    >
      {
        services.map((service, i) => {
          const accent = accentColors[i];
          const isLarge = i === 0 || i === 3;

          return (
            <div
              class:list={[
                "service-card group relative overflow-hidden rounded-2xl border border-white/8 bg-linear-to-br backdrop-blur-sm cursor-default transition-all duration-500 hover:border-white/15",
                bentoSizes[i],
                gradients[i],
              ]}
              data-stagger-item
            >
              {/* Decorative corner glow */}
              <div
                class:list={[
                  "absolute -top-12 -right-12 w-32 h-32 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700",
                  accent.bg,
                ]}
              />

              {/* Decorative grid pattern for large cards */}
              {isLarge && (
                <div
                  class="absolute inset-0 opacity-[0.03] group-hover:opacity-[0.06] transition-opacity duration-500"
                  style="background-image: radial-gradient(circle, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 24px 24px;"
                />
              )}

              <div
                class:list={[
                  "relative z-10 h-full flex flex-col",
                  isLarge ? "p-8" : "p-6",
                ]}
              >
                {/* Top row: icon + number */}
                <div class="flex items-start justify-between">
                  <div
                    class:list={[
                      "flex items-center justify-center rounded-xl border backdrop-blur-sm transition-all duration-300 group-hover:scale-110",
                      accent.border,
                      accent.bg,
                      isLarge ? "w-14 h-14" : "w-11 h-11",
                    ]}
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      class:list={[
                        accent.text,
                        isLarge ? "w-7 h-7" : "w-5 h-5",
                      ]}
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d={iconPaths[service.icon]}
                      />
                    </svg>
                  </div>
                  <span class="text-white/8 font-black text-4xl leading-none select-none group-hover:text-white/12 transition-colors duration-300">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                </div>

                {/* Content */}
                <div class:list={[isLarge ? "mt-auto" : "mt-4"]}>
                  <h3
                    class:list={[
                      "font-black text-white mb-2",
                      isLarge ? "text-2xl" : "text-lg",
                    ]}
                  >
                    {service.title}
                  </h3>
                  <p
                    class:list={[
                      "text-white/40 leading-relaxed mb-4",
                      isLarge ? "text-sm" : "text-xs",
                    ]}
                  >
                    {service.description}
                  </p>

                  {/* Feature tags */}
                  <div class="flex flex-wrap gap-1.5">
                    {service.features
                      .slice(0, isLarge ? 4 : 2)
                      .map((feature: string) => (
                        <span
                          class:list={[
                            "px-2.5 py-1 rounded-md text-[10px] font-semibold border transition-colors duration-300",
                            accent.border,
                            accent.text,
                            accent.bg,
                            "group-hover:bg-white/8",
                          ]}
                        >
                          {feature}
                        </span>
                      ))}
                    {!isLarge && service.features.length > 2 && (
                      <span class="px-2.5 py-1 rounded-md text-[10px] font-semibold text-white/30 border border-white/6 bg-white/3">
                        +{service.features.length - 2}
                      </span>
                    )}
                  </div>
                </div>
              </div>

              {/* Bottom accent line */}
              <div
                class:list={[
                  "absolute bottom-0 left-0 right-0 h-0.5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-linear-to-r",
                  gradients[i].replace("/20", "/60"),
                ]}
              />
            </div>
          );
        })
      }
    </div>
  </Container>
</Section>
