---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import AnimatedCounter from '@components/animations/AnimatedCounter.astro';
---

<Section id="about" padding="lg">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Text -->
      <div>
        <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest font-bold mb-4" data-reveal-y="30">
          <span class="forge-gradient-text">Sobre Nosotros</span>
        </p>
        <h2 class="scroll-reveal opacity-0 text-4xl md:text-5xl font-black text-white mb-6 leading-tight" data-reveal-y="30" data-reveal-delay="0.1">
          Tecnologia con proposito, resultados medibles
        </h2>
        <div class="space-y-4">
          <p class="scroll-reveal opacity-0 text-white/50 leading-relaxed" data-reveal-y="20" data-reveal-delay="0.2">
            Somos un equipo de ingenieros, arquitectos y estrategas tecnologicos con mas
            de una decada de experiencia construyendo productos digitales que transforman
            negocios.
          </p>
          <p class="scroll-reveal opacity-0 text-white/50 leading-relaxed" data-reveal-y="20" data-reveal-delay="0.3">
            Nuestro enfoque combina excelencia tecnica con vision de negocio. No solo
            escribimos codigo — diseñamos soluciones que escalan, perduran y generan
            valor real.
          </p>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="scroll-reveal opacity-0 relative" data-reveal-x="-60">
        <div class="forge-card p-8 bg-linear-to-br from-pink-500/5 to-orange-500/5">
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center p-4">
              <span class="text-4xl font-black forge-gradient-text">
                <AnimatedCounter value={150} suffix="+" />
              </span>
              <p class="text-sm text-white/40 mt-1">Proyectos</p>
            </div>
            <div class="text-center p-4">
              <span class="text-4xl font-black forge-gradient-text">
                <AnimatedCounter value={80} suffix="+" />
              </span>
              <p class="text-sm text-white/40 mt-1">Clientes</p>
            </div>
            <div class="text-center p-4">
              <span class="text-4xl font-black forge-gradient-text">
                <AnimatedCounter value={25} suffix="+" />
              </span>
              <p class="text-sm text-white/40 mt-1">Expertos</p>
            </div>
            <div class="text-center p-4">
              <span class="text-4xl font-black forge-gradient-text">
                <AnimatedCounter value={12} />
              </span>
              <p class="text-sm text-white/40 mt-1">Anios</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>
