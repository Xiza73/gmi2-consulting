---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import services from '@/data/services.json';

const bentoSizes = [
  'md:col-span-2 md:row-span-2',
  'md:col-span-1 md:row-span-1',
  'md:col-span-1 md:row-span-1',
  'md:col-span-1 md:row-span-2',
  'md:col-span-1 md:row-span-1',
  'md:col-span-1 md:row-span-1',
];

const gradients = [
  'from-pink-500/20 to-orange-500/20',
  'from-orange-500/20 to-yellow-500/20',
  'from-violet-500/20 to-pink-500/20',
  'from-cyan-500/20 to-blue-500/20',
  'from-yellow-500/20 to-orange-500/20',
  'from-pink-500/20 to-violet-500/20',
];

const accentColors = [
  { border: 'border-pink-500/30', text: 'text-pink-400', bg: 'bg-pink-500/10', glow: 'shadow-pink-500/20' },
  { border: 'border-orange-500/30', text: 'text-orange-400', bg: 'bg-orange-500/10', glow: 'shadow-orange-500/20' },
  { border: 'border-violet-500/30', text: 'text-violet-400', bg: 'bg-violet-500/10', glow: 'shadow-violet-500/20' },
  { border: 'border-cyan-500/30', text: 'text-cyan-400', bg: 'bg-cyan-500/10', glow: 'shadow-cyan-500/20' },
  { border: 'border-yellow-500/30', text: 'text-yellow-400', bg: 'bg-yellow-500/10', glow: 'shadow-yellow-500/20' },
  { border: 'border-pink-500/30', text: 'text-pink-400', bg: 'bg-pink-500/10', glow: 'shadow-pink-500/20' },
];

const iconPaths: Record<string, string> = {
  code: 'M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75h1.5m9 0h-9M9.75 9l2.25 2.25L9.75 13.5m4.5-4.5L16.5 11.25 14.25 13.5',
  rocket: 'M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.63 8.41m5.96 5.96a14.93 14.93 0 0 1-5.96 2.39m0 0 2.39-5.96M3.54 17.96l1.06-1.06m0 0 1.06 1.06M4.6 16.9l-1.06 1.06M4.6 16.9l1.06-1.06',
  smartphone: 'M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3',
  cloud: 'M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z',
  lightbulb: 'M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18',
  settings: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.212-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z',
};
---

<Section id="build" padding="lg">
  <Container>
    <div class="text-center mb-16">
      <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest font-bold mb-4" data-reveal-y="30">
        <span class="forge-gradient-text">Que Construimos</span>
      </p>
      <h2 class="scroll-reveal opacity-0 text-4xl md:text-6xl font-black text-white" data-reveal-y="30" data-reveal-delay="0.1">
        Servicios
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:auto-rows-[200px]" data-stagger-grid>
      {services.map((service, i) => {
        const accent = accentColors[i];
        const isLarge = i === 0 || i === 3;
        return (
          <div
            class:list={[
              'service-card group relative overflow-hidden rounded-2xl border border-white/8 bg-linear-to-br backdrop-blur-sm cursor-default transition-all duration-500 hover:border-white/15',
              bentoSizes[i],
              gradients[i],
            ]}
            data-stagger-item
          >
            {/* Decorative corner glow */}
            <div class:list={['absolute -top-12 -right-12 w-32 h-32 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700', accent.bg]} />

            {/* Decorative grid pattern for large cards */}
            {isLarge && (
              <div class="absolute inset-0 opacity-[0.03] group-hover:opacity-[0.06] transition-opacity duration-500"
                style="background-image: radial-gradient(circle, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 24px 24px;"
              />
            )}

            <div class:list={['relative z-10 h-full flex flex-col', isLarge ? 'p-8' : 'p-6']}>
              {/* Top row: icon + number */}
              <div class="flex items-start justify-between mb-auto">
                <div class:list={['flex items-center justify-center rounded-xl border backdrop-blur-sm transition-all duration-300 group-hover:scale-110', accent.border, accent.bg, isLarge ? 'w-14 h-14' : 'w-11 h-11']}>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class:list={[accent.text, isLarge ? 'w-7 h-7' : 'w-5 h-5']}
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.icon]} />
                  </svg>
                </div>
                <span class="text-white/8 font-black text-4xl leading-none select-none group-hover:text-white/12 transition-colors duration-300">
                  {String(i + 1).padStart(2, '0')}
                </span>
              </div>

              {/* Content */}
              <div class="mt-auto">
                <h3 class:list={['font-black text-white mb-2', isLarge ? 'text-2xl' : 'text-lg']}>
                  {service.title}
                </h3>
                <p class:list={['text-white/40 leading-relaxed mb-4', isLarge ? 'text-sm' : 'text-xs']}>
                  {service.description}
                </p>

                {/* Feature tags */}
                <div class="flex flex-wrap gap-1.5">
                  {service.features.slice(0, isLarge ? 4 : 2).map((feature: string) => (
                    <span class:list={['px-2.5 py-1 rounded-md text-[10px] font-semibold border transition-colors duration-300', accent.border, accent.text, accent.bg, 'group-hover:bg-white/8']}>
                      {feature}
                    </span>
                  ))}
                  {!isLarge && service.features.length > 2 && (
                    <span class="px-2.5 py-1 rounded-md text-[10px] font-semibold text-white/30 border border-white/6 bg-white/3">
                      +{service.features.length - 2}
                    </span>
                  )}
                </div>
              </div>
            </div>

            {/* Bottom accent line */}
            <div class:list={['absolute bottom-0 left-0 right-0 h-0.5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-linear-to-r', gradients[i].replace('/20', '/60')]} />
          </div>
        );
      })}
    </div>
  </Container>
</Section>
