---
import type { Locale } from '@/i18n/config';
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import { CTA_CONTENT } from '../../data/cta.data';
import { UI } from '@/i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = CTA_CONTENT[locale];
const ui = UI[locale];

const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xyzplaceholder';
---

<Section id="contact" padding="xl" class="relative overflow-hidden forge-mesh-bg">
  <Container size="md">
    <div class="text-center scroll-reveal opacity-0" data-reveal-y="40">
      <h2 class="text-5xl md:text-7xl font-black text-white mb-6 leading-[0.95]">
        {content.title.line1}<br />
        <span class="forge-gradient-text">{content.title.accent}</span>
      </h2>

      <p class="text-lg text-white/50 max-w-xl mx-auto mb-12">
        {content.description}
      </p>
    </div>

    <!-- Contact Form -->
    <div class="max-w-2xl mx-auto scroll-reveal opacity-0" data-reveal-y="40">
      <h3 class="text-2xl font-bold text-white mb-8 text-center">{content.form.heading}</h3>

      <form
        action={FORMSPREE_ENDPOINT}
        method="POST"
        class="space-y-6"
        id="contact-form"
      >
        <!-- Hidden locale field -->
        <input type="hidden" name="locale" value={locale} />

        <!-- Name + Email -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="contact-name" class="text-sm text-white/70 font-medium">
              {ui.contactName} <span class="text-pink-400">*</span>
            </label>
            <input
              id="contact-name"
              type="text"
              name="name"
              required
              placeholder={locale === 'es' ? 'Tu nombre' : 'Your name'}
              class="bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/25 focus:border-pink-500 focus:outline-none focus:ring-1 focus:ring-pink-500 transition-colors"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-email" class="text-sm text-white/70 font-medium">
              {ui.contactEmail} <span class="text-pink-400">*</span>
            </label>
            <input
              id="contact-email"
              type="email"
              name="email"
              required
              placeholder={locale === 'es' ? 'tu@empresa.com' : 'you@company.com'}
              class="bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/25 focus:border-pink-500 focus:outline-none focus:ring-1 focus:ring-pink-500 transition-colors"
            />
          </div>
        </div>

        <!-- Company -->
        <div class="flex flex-col gap-2">
          <label for="contact-company" class="text-sm text-white/70 font-medium">
            {ui.contactCompany}
          </label>
          <input
            id="contact-company"
            type="text"
            name="company"
            placeholder={locale === 'es' ? 'Tu empresa (opcional)' : 'Your company (optional)'}
            class="bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/25 focus:border-pink-500 focus:outline-none focus:ring-1 focus:ring-pink-500 transition-colors"
          />
        </div>

        <!-- Message -->
        <div class="flex flex-col gap-2">
          <label for="contact-message" class="text-sm text-white/70 font-medium">
            {ui.contactMessage} <span class="text-pink-400">*</span>
          </label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows={5}
            placeholder={locale === 'es' ? 'Contanos sobre tus procesos y objetivos...' : 'Tell us about your processes and goals...'}
            class="bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/25 focus:border-pink-500 focus:outline-none focus:ring-1 focus:ring-pink-500 transition-colors resize-none"
          ></textarea>
        </div>

        <!-- Submit -->
        <div class="flex justify-center">
          <button
            type="submit"
            class="group inline-flex items-center gap-2 px-8 py-4 text-lg font-bold text-white bg-linear-to-r from-pink-500 via-orange-500 to-yellow-500 rounded-full hover:shadow-xl hover:shadow-pink-500/25 transition-all hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
          >
            {ui.contactSend}
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </button>
        </div>
      </form>

      <!-- Success message (hidden by default) -->
      <div id="form-success" class="hidden text-center py-8">
        <div class="text-5xl mb-4">✓</div>
        <p class="text-xl font-bold text-white">{content.form.successMessage}</p>
      </div>

      <!-- Fallback email link -->
      <div class="mt-10 pt-8 border-t border-white/10 text-center">
        <p class="text-sm text-white/40 mb-3">{content.form.fallback}</p>
        <a
          href={content.cta.secondary.href}
          class="text-white/60 hover:text-pink-400 transition-colors font-medium"
        >
          {content.cta.secondary.label}
        </a>
      </div>
    </div>
  </Container>
</Section>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('form-success');

    if (!form || !success) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;

      try {
        const data = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (response.ok) {
          form.classList.add('hidden');
          success.classList.remove('hidden');
        } else {
          if (submitBtn) submitBtn.disabled = false;
        }
      } catch {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  });

  document.addEventListener('astro:before-swap', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('form-success');
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    if (form) form.classList.remove('hidden');
    if (success) success.classList.add('hidden');
    if (submitBtn) submitBtn.disabled = false;
  });
</script>
