---
import type { Locale } from '@/i18n/config';
import HeroBlob from '@components/three/HeroBlob';
import { HERO_CONTENT } from '../../data/hero.data';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = HERO_CONTENT[locale];
---

<section class="relative min-h-screen flex items-center overflow-hidden forge-mesh-bg">
  <!-- 3D Blob — full viewport background -->
  <div class="absolute inset-0">
    <HeroBlob client:only="react" />
  </div>

  <!-- Dark vignette for text readability -->
  <div class="absolute inset-0 z-1 pointer-events-none bg-radial-[circle_at_center] from-black/60 via-black/30 to-transparent"></div>

  <!-- Content Overlay -->
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-32 pb-20 text-center">
    <div class="forge-hero-eyebrow opacity-0">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-black/30 backdrop-blur-sm border border-white/15 text-sm font-medium text-white/90 mb-8">
        <span class="w-2 h-2 rounded-full bg-linear-to-r from-pink-500 to-orange-500 animate-pulse"></span>
        {content.eyebrow}
      </span>
    </div>

    <h1 class="forge-hero-title opacity-0 text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-black tracking-tighter text-white leading-[0.9] drop-shadow-[0_4px_30px_rgba(0,0,0,0.5)]">
      {content.title.line1}
      <span class="block forge-gradient-text drop-shadow-[0_4px_30px_rgba(0,0,0,0.4)]">{content.title.line2}</span>
    </h1>

    <p class="forge-hero-description opacity-0 mt-8 text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed drop-shadow-[0_2px_10px_rgba(0,0,0,0.5)]">
      {content.description}
    </p>

    <div class="forge-hero-cta opacity-0 mt-10 flex flex-wrap justify-center gap-4">
      <a
        href={content.cta.primary.href}
        class="px-8 py-4 text-lg font-bold text-white bg-linear-to-r from-pink-500 via-orange-500 to-yellow-500 rounded-full hover:shadow-xl hover:shadow-pink-500/25 transition-all hover:scale-105 shadow-lg"
      >
        {content.cta.primary.label}
      </a>
      <a
        href={content.cta.secondary.href}
        class="px-8 py-4 text-lg font-bold text-white border-2 border-white/30 rounded-full hover:border-white/50 backdrop-blur-sm bg-white/5 transition-all"
      >
        {content.cta.secondary.label}
      </a>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function initForgeHero() {
    const hero = document.querySelector('.forge-hero-title');
    if (!hero) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set('.forge-hero-eyebrow, .forge-hero-title, .forge-hero-description, .forge-hero-cta', {
        opacity: 1,
      });
      return;
    }

    const tl = gsap.timeline({ defaults: { ease: 'elastic.out(1, 0.5)' } });

    tl.to('.forge-hero-eyebrow', { opacity: 1, y: 0, duration: 0.8, ease: 'power4.out' }, 0.2)
      .to('.forge-hero-title', { opacity: 1, scale: 1, duration: 1.2 }, 0.4)
      .to('.forge-hero-description', { opacity: 1, y: 0, duration: 0.8, ease: 'power4.out' }, 0.8)
      .to('.forge-hero-cta', { opacity: 1, y: 0, duration: 0.8, ease: 'back.out(1.7)' }, 1);
  }

  document.addEventListener('astro:page-load', initForgeHero);
</script>
