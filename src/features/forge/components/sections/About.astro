---
import type { Locale } from '@/i18n/config';
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import AnimatedCounter from '@components/animations/AnimatedCounter.astro';
import { ABOUT_CONTENT, ABOUT_STATS } from '../../data/about.data';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = ABOUT_CONTENT[locale];
const stats = ABOUT_STATS[locale];
---

<Section id="about" padding="lg">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Text -->
      <div>
        <p class="scroll-reveal opacity-0 text-sm uppercase tracking-widest font-bold mb-4" data-reveal-y="30">
          <span class="forge-gradient-text">{content.eyebrow}</span>
        </p>
        <h2 class="scroll-reveal opacity-0 text-4xl md:text-5xl font-black text-white mb-6 leading-tight" data-reveal-y="30" data-reveal-delay="0.1">
          {content.title}
        </h2>
        <div class="space-y-4">
          {content.paragraphs.map((paragraph, i) => (
            <p class="scroll-reveal opacity-0 text-white/50 leading-relaxed" data-reveal-y="20" data-reveal-delay={String(0.2 + i * 0.1)}>
              {paragraph}
            </p>
          ))}
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="scroll-reveal opacity-0 relative" data-reveal-x="-60">
        <div class="forge-card p-8 bg-linear-to-br from-pink-500/5 to-orange-500/5">
          <div class="grid grid-cols-2 gap-6">
            {stats.map((stat) => (
              <div class="text-center p-4">
                <span class="text-4xl font-black forge-gradient-text">
                  <AnimatedCounter value={stat.value} suffix={stat.suffix} />
                </span>
                <p class="text-sm text-white/40 mt-1">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>
