---
import Container from '@components/layout/Container.astro';
import { NAV_BRAND, NAV_LINKS, NAV_CTA } from '../data/nav.data';
---

<nav class="forge-nav fixed top-0 left-0 right-0 z-50" transition:persist>
  <Container>
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href={NAV_BRAND.href} class="text-xl font-black tracking-tight text-white">
        {NAV_BRAND.text}<span class="forge-gradient-text">{NAV_BRAND.accent}</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {NAV_LINKS.map((link) => (
          <a href={link.href} class="text-sm text-white/60 hover:text-white transition-colors font-medium">{link.label}</a>
        ))}
        <a
          href={NAV_CTA.href}
          class="px-5 py-2 text-sm font-bold text-white bg-linear-to-r from-pink-500 to-orange-500 rounded-full hover:shadow-lg hover:shadow-pink-500/25 transition-all"
        >
          {NAV_CTA.label}
        </a>
      </div>
    </div>
  </Container>
</nav>
