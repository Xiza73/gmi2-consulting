---
import { ClientRouter } from 'astro:transitions';
import SEOHead from '@components/seo/SEOHead.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import type { Locale } from '@/i18n/config';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  bodyClass?: string;
}

const {
  title,
  description,
  locale,
  image,
  type = 'website',
  noindex = false,
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEOHead title={title} description={description} locale={locale} image={image} type={type} noindex={noindex} />
    <link rel="alternate" hreflang="es" href={`${Astro.site}`} />
    <link rel="alternate" hreflang="en" href={`${Astro.site}en`} />
    <link rel="alternate" hreflang="x-default" href={`${Astro.site}`} />
    <StructuredData
      data={{
        '@type': 'Organization',
        name: 'GMI2 Consulting',
        url: 'https://gmi2consulting.com',
        description: 'Consultoria IT especializada en desarrollo full-stack, productos SaaS y transformacion digital.',
        inLanguage: locale === 'es' ? 'es-PE' : 'en-US',
        sameAs: [],
      }}
    />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class:list={['min-h-screen antialiased', bodyClass]}>
    <slot />

    <script>
      import { cleanupAnimations, initAllAnimations } from '@/lib/animations';

      document.addEventListener('astro:page-load', () => {
        initAllAnimations();
      });

      document.addEventListener('astro:before-swap', () => {
        cleanupAnimations();
      });
    </script>

    <script is:inline>
      (function() {
        var STORAGE_KEY = 'gmi2-locale-pref';
        var DISMISS_KEY = 'gmi2-locale-dismissed';

        if (localStorage.getItem(STORAGE_KEY) || sessionStorage.getItem(DISMISS_KEY)) return;

        var pageLang = document.documentElement.lang;
        var browserLang = (navigator.language || '').slice(0, 2);

        if (pageLang === browserLang) return;
        if (browserLang !== 'es' && browserLang !== 'en') return;

        var isEn = pageLang === 'es';
        var msg = isEn ? 'English version available' : 'Versión en español disponible';
        var switchText = isEn ? 'Switch' : 'Cambiar';
        var switchUrl = isEn ? '/en' : '/';

        var banner = document.createElement('div');
        banner.id = 'locale-banner';
        banner.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;background:rgba(15,15,15,0.95);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.1);border-radius:0.75rem;padding:0.75rem 1rem;display:flex;align-items:center;gap:0.75rem;font-family:Inter,system-ui,sans-serif;font-size:0.875rem;color:rgba(255,255,255,0.85);box-shadow:0 4px 24px rgba(0,0,0,0.3);max-width:320px;';

        banner.innerHTML = '<span>' + msg + '</span>' +
          '<a href="' + switchUrl + '" style="padding:0.375rem 0.75rem;background:linear-gradient(135deg,#ec4899,#f97316);color:white;border-radius:0.5rem;font-weight:600;text-decoration:none;white-space:nowrap;" onclick="localStorage.setItem(\'' + STORAGE_KEY + '\',\'' + (isEn ? 'en' : 'es') + '\')">' + switchText + '</a>' +
          '<button onclick="this.parentElement.remove();sessionStorage.setItem(\'' + DISMISS_KEY + '\',\'1\')" style="background:none;border:none;color:rgba(255,255,255,0.5);cursor:pointer;font-size:1rem;padding:0.25rem;">✕</button>';

        document.body.appendChild(banner);
      })();
    </script>
  </body>
</html>
