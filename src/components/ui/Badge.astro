---
interface Props {
  variant?: 'default' | 'primary' | 'accent';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variantMap = {
  default: 'bg-white/10 text-white/80 border border-white/20',
  primary: 'bg-primary-500/20 text-primary-300 border border-primary-500/30',
  accent: 'bg-accent-pink/20 text-accent-pink border border-accent-pink/30',
};
---

<span
  class:list={[
    'inline-flex items-center rounded-full px-3 py-1 text-xs font-medium tracking-wide uppercase',
    variantMap[variant],
    className,
  ]}
>
  <slot />
</span>
