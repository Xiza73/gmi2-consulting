---
interface Props {
  id?: string;
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg' | 'xl';
  background?: 'transparent' | 'dark' | 'light' | 'gradient';
}

const {
  id,
  class: className = '',
  padding = 'lg',
  background = 'transparent',
} = Astro.props;

const paddingMap = {
  none: '',
  sm: 'py-12 md:py-16',
  md: 'py-16 md:py-24',
  lg: 'py-20 md:py-32',
  xl: 'py-24 md:py-40',
};

const bgMap = {
  transparent: '',
  dark: 'bg-surface-dark',
  light: 'bg-surface-light',
  gradient: 'bg-gradient-to-b from-transparent to-black/5',
};
---

<section
  id={id}
  class:list={['relative w-full', paddingMap[padding], bgMap[background], className]}
>
  <slot />
</section>
