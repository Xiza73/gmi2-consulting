---
interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
}

const { class: className = '', size = 'lg' } = Astro.props;

const sizeMap = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-7xl',
  xl: 'max-w-[1400px]',
  full: 'max-w-full',
};
---

<div class:list={['mx-auto w-full px-4 sm:px-6 lg:px-8', sizeMap[size], className]}>
  <slot />
</div>
