---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/features/forge/styles/forge.css';
---

<BaseLayout
  title="404 — GMI2 Consulting"
  description="Página no encontrada / Page not found"
  locale="es"
  noindex={true}
>
  <main class="forge-page min-h-screen flex flex-col items-center justify-center px-4 text-center">
    <p class="text-sm font-semibold tracking-widest text-white/40 uppercase mb-6">Error</p>

    <h1 class="text-[10rem] md:text-[16rem] font-black leading-none forge-gradient-text mb-8">
      404
    </h1>

    <div class="space-y-2 mb-12">
      <p class="text-2xl md:text-3xl font-bold text-white">Página no encontrada</p>
      <p class="text-lg text-white/50">Page not found</p>
    </div>

    <a
      href="/"
      class="px-10 py-5 text-lg font-black text-white bg-linear-to-r from-pink-500 via-orange-500 to-yellow-500 rounded-full hover:shadow-xl hover:shadow-pink-500/25 transition-all hover:scale-105"
    >
      Volver al inicio / Back to home
    </a>
  </main>
</BaseLayout>
